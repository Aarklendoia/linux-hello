#%PAM-1.0
# PAM configuration for KDE Plasma Screenlock with Linux Hello
# Enables screen unlock via facial authentication

# Facial authentication first
auth sufficient /home/edtech/Documents/linux-hello-rust/target/debug/libpam_linux_hello.so context=screenlock timeout_ms=3000 debug

# If facial authentication fails, use the password
auth required pam_unix.so nullok try_first_pass

# Account validation
account required pam_permit.so

# Session
session required pam_permit.so
