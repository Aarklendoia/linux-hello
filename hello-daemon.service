[Unit]
Description=Linux Hello Face Authentication Daemon
Documentation=file:///usr/share/doc/linux-hello/README.md
After=dbus.service

[Service]
Type=simple
ExecStart=/usr/bin/hello-daemon
Environment=ORT_DYLIB_PATH=/usr/lib/x86_64-linux-gnu/libonnxruntime.so.1.23
Restart=on-failure
RestartSec=2s
# Stop retrying if the daemon crashes 5 times in 60s (avoids an infinite loop).
# The PAM module falls back to the password, so security is still ensured.
StartLimitIntervalSec=60s
StartLimitBurst=5

# Security settings
ProtectSystem=strict
# ProtectHome=yes (fully inaccessible) breaks the ReadWritePaths exception
# below under unprivileged user namespaces (--user units can't rely on the
# same bind-mount punch-through as root system services); read-only still
# hides other users' homes from write access while letting our own
# ReadWritePaths grant work.
ProtectHome=read-only
NoNewPrivileges=true
ReadWritePaths=/home/%u/.local/share/linux-hello %t /run/lock /run/hello-pam

# Timeout settings
TimeoutStartSec=15
TimeoutStopSec=5

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hello-daemon

[Install]
WantedBy=default.target
