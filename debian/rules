#!/usr/bin/make -f
# -*- makefile -*-

include /usr/share/dpkg/architecture.mk

export DH_VERBOSE=1
export CARGO_HOME=$(CURDIR)/target/cargo
export RUSTUP_TOOLCHAIN=stable
export PATH:=$(HOME)/.cargo/bin:$(PATH)

%:
	dh $@

override_dh_auto_clean:
	# Do not erase the cargo cache: preserves incremental compilation.
	# In CI, the target directory is absent anyway (clean clone).
	true

override_dh_auto_build:
	cargo build --release --verbose
	# Qt6 GUI is built as a simple Rust binary by cargo, QML files are handled at runtime

override_dh_auto_test:
	# Skip tests (they require specific hardware/D-Bus setup)
	echo "Skipping automated tests (hardware requirements)"

override_dh_auto_install:
	# Install binaries
	mkdir -p $(CURDIR)/debian/tmp/usr/bin
	cp $(CURDIR)/target/release/hello-daemon $(CURDIR)/debian/tmp/usr/bin/
	cp $(CURDIR)/target/release/hello-daemon-system $(CURDIR)/debian/tmp/usr/bin/
	cp $(CURDIR)/target/release/linux-hello $(CURDIR)/debian/tmp/usr/bin/
	
	# Install PAM module
	# Must go under the multiarch security dir (e.g. /lib/x86_64-linux-gnu/security/)
	# for PAM's default module search path to find it — /lib/security/ is not on
	# that path on Debian/Ubuntu and silently fails to load the module.
	mkdir -p $(CURDIR)/debian/tmp/lib/$(DEB_HOST_MULTIARCH)/security
	cp $(CURDIR)/target/release/libpam_linux_hello.so \
	   $(CURDIR)/debian/tmp/lib/$(DEB_HOST_MULTIARCH)/security/pam_linux_hello.so

	# Install systemd user service
	mkdir -p $(CURDIR)/debian/tmp/usr/lib/systemd/user
	cp $(CURDIR)/hello-daemon.service $(CURDIR)/debian/tmp/usr/lib/systemd/user/

	# Install systemd tmpfiles.d (creates /run/hello-pam/ at boot, sticky+world-writable,
	# and the cross-process camera lock used by hello_daemon::camera::CameraLock)
	mkdir -p $(CURDIR)/debian/tmp/usr/lib/tmpfiles.d
	printf 'd /run/hello-pam 1777 root root -\nf /run/lock/linux-hello-camera.lock 0666 root root -\n' > $(CURDIR)/debian/tmp/usr/lib/tmpfiles.d/linux-hello.conf

	# Install PAM auto-activation: system unit + timer + detection script + shared lib
	mkdir -p $(CURDIR)/debian/tmp/usr/lib/systemd/system
	cp $(CURDIR)/linux-hello-pam-autoconfigure.service $(CURDIR)/debian/tmp/usr/lib/systemd/system/
	cp $(CURDIR)/linux-hello-pam-autoconfigure.timer $(CURDIR)/debian/tmp/usr/lib/systemd/system/
	# SDDM (login screen) system listener — enabled only via install-pam.sh's
	# opt-in SDDM step, never unconditionally at package install time (see
	# debian/libpam-linux-hello.postinst and install-pam.sh).
	cp $(CURDIR)/hello-daemon-system.service $(CURDIR)/debian/tmp/usr/lib/systemd/system/
	mkdir -p $(CURDIR)/debian/tmp/usr/bin
	cp $(CURDIR)/linux-hello-pam-autoconfigure $(CURDIR)/debian/tmp/usr/bin/
	chmod 0755 $(CURDIR)/debian/tmp/usr/bin/linux-hello-pam-autoconfigure
	mkdir -p $(CURDIR)/debian/tmp/usr/lib/linux-hello
	cp $(CURDIR)/pam-lib.sh $(CURDIR)/debian/tmp/usr/lib/linux-hello/
	
	# Install documentation
	mkdir -p $(CURDIR)/debian/tmp/usr/share/doc/linux-hello
	cp $(CURDIR)/README.md $(CURDIR)/debian/tmp/usr/share/doc/linux-hello/
	cp $(CURDIR)/docs/QUICKSTART.md $(CURDIR)/debian/tmp/usr/share/doc/linux-hello/
	cp $(CURDIR)/docs/INTEGRATION_GUIDE.md $(CURDIR)/debian/tmp/usr/share/doc/linux-hello/
	cp $(CURDIR)/docs/PAM_MODULE.md $(CURDIR)/debian/tmp/usr/share/doc/linux-hello/
	cp $(CURDIR)/sudo-linux-hello.pam $(CURDIR)/debian/tmp/usr/share/doc/linux-hello/
	
	# KDE lock screen QML overlay: stored in /usr/share/linux-hello/lockscreen/.
	# postinst installs it in place via dpkg-divert.
	mkdir -p $(CURDIR)/debian/tmp/usr/share/linux-hello/lockscreen
	cp $(CURDIR)/qml/lockscreen/MainBlock.qml \
	   $(CURDIR)/debian/tmp/usr/share/linux-hello/lockscreen/

	# SDDM greeter status indicator QML overlay: stored in
	# /usr/share/linux-hello/sddm/. install-pam.sh installs it in place via
	# dpkg-divert (opt-in, unlike the lockscreen overlay above — matches
	# SDDM support being opt-in everywhere else in this project).
	mkdir -p $(CURDIR)/debian/tmp/usr/share/linux-hello/sddm
	cp $(CURDIR)/qml/sddm/Login.qml \
	   $(CURDIR)/debian/tmp/usr/share/linux-hello/sddm/

	# Install ONNX models (downloaded by build.rs during cargo build --release)
	mkdir -p $(CURDIR)/debian/tmp/usr/share/linux-hello/models
	cp "$${XDG_DATA_HOME:-$(HOME)/.local/share}/linux-hello/models/det_500m.onnx" \
	   $(CURDIR)/debian/tmp/usr/share/linux-hello/models/
	cp "$${XDG_DATA_HOME:-$(HOME)/.local/share}/linux-hello/models/w600k_mbf.onnx" \
	   $(CURDIR)/debian/tmp/usr/share/linux-hello/models/

	# Install example config
	mkdir -p $(CURDIR)/debian/tmp/etc/linux-hello
	cp $(CURDIR)/linux-hello.config.toml.example $(CURDIR)/debian/tmp/etc/linux-hello/config.toml.example
	
	# Install GUI files - Qt6 QML module structure
	mkdir -p $(CURDIR)/debian/tmp/usr/bin
	mkdir -p $(CURDIR)/debian/tmp/usr/share/qt6/qml/Linux/Hello
	mkdir -p $(CURDIR)/debian/tmp/usr/share/icons/hicolor/scalable/apps
	mkdir -p $(CURDIR)/debian/tmp/usr/share/applications
	mkdir -p $(CURDIR)/debian/tmp/usr/share/doc/linux-hello-gui
	
	# GUI installation - copy QML files to Qt6 module location
	cp -r $(CURDIR)/linux_hello_config/qml/* $(CURDIR)/debian/tmp/usr/share/qt6/qml/Linux/Hello/
	
	# Application icon: copied directly in override_dh_install (not via debian/tmp, to avoid the dh_install renaming bug)

override_dh_install:
	dh_install
	# Ensure GUI QML files go to linux-hello-gui package
	mkdir -p $(CURDIR)/debian/linux-hello-gui/usr/share/qt6/qml/Linux/Hello
	cp -r $(CURDIR)/debian/tmp/usr/share/qt6/qml/Linux/Hello/* $(CURDIR)/debian/linux-hello-gui/usr/share/qt6/qml/Linux/Hello/ 2>/dev/null || true
	# Install app icon with correct filename (dh_install does not support renaming)
	mkdir -p $(CURDIR)/debian/linux-hello-gui/usr/share/icons/hicolor/scalable/apps
	cp $(CURDIR)/linux_hello_config/qml/icons/app-icon.svg $(CURDIR)/debian/linux-hello-gui/usr/share/icons/hicolor/scalable/apps/linux-hello.svg

override_dh_missing:
	dh_missing --list-missing

override_dh_strip:
	# Keep symbols for debugging
	dh_strip --no-automatic-dbgsym

.PHONY: override_dh_auto_build override_dh_auto_test override_dh_auto_install override_dh_strip
